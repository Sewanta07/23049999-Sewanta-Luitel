<%@ Page Title="Contact" Language="C#" MasterPageFile="~/Site.Master" AutoEventWireup="true" %>

<asp:Content ID="BodyContent" ContentPlaceHolderID="MainContent" runat="server">
    <main class="app-shell">
        <h2>Contact & Support</h2>
        <p>Need help with bookings, tickets, or report access? Contact the support desk below.</p>

        <div class="row">
            <section class="col-md-6">
                <article class="card">
                    <div class="card-body">
                        <h4 class="card-title">Support Desk</h4>
                        <p><strong>Email:</strong> admin@cinema.local</p>
                        <p><strong>Phone:</strong> +977-9800000000</p>
                        <p><strong>Office Hours:</strong> Sunday to Friday, 10:00 AM - 5:00 PM</p>
                    </div>
                </article>
            </section>

            <section class="col-md-6">
                <article class="card">
                    <div class="card-body">
                        <h4 class="card-title">Support Notes</h4>
                        <p><strong>Response Time:</strong> Within 1 business day.</p>
                        <p><strong>For Faster Help:</strong> Include your username and ticket or booking ID.</p>
                        <p><strong>Issue Reports:</strong> Mention the page name and a short error description.</p>
                    </div>
                </article>
            </section>
        </div>
    </main>
</asp:Content>
